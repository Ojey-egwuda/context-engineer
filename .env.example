# ── Anthropic ────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ── LangSmith (optional but recommended for observability) ───────────────────
# Get your key at: https://eu.smith.langchain.com
LANGSMITH_API_KEY=your_langsmith_api_key_here
LANGCHAIN_TRACING_V2=true
LANGCHAIN_ENDPOINT=https://eu.smith.langchain.com
LANGCHAIN_PROJECT=context-engineer

# ── App config ───────────────────────────────────────────────────────────────
# Folder where the SQLite offload database will be stored
OFFLOAD_DB_PATH=data/offload_store.db
